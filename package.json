{
  "name": "@searvora/cli",
  "version": "0.1.0",
  "private": false,
  "description": "Agent-ready command line interface for the Searvora SEO platform",
  "type": "module",
  "bin": {
    "searvora": "src/index.js"
  },
  "scripts": {
    "test": "node --test tests/*.test.js tests/unit/*.test.js tests/integration/*.test.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:integration": "node --test tests/integration/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-lines=80 --test-coverage-functions=80 --test-coverage-branches=70 tests/*.test.js tests/unit/*.test.js tests/integration/*.test.js",
    "check": "node --check src/index.js && node --check src/lib/*.js && node --check src/commands/*.js"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "license": "MIT",
  "author": "Searvora",
  "homepage": "https://searvora.com/cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zzxthy/searvora-cli.git"
  },
  "bugs": {
    "url": "https://github.com/zzxthy/searvora-cli/issues"
  },
  "keywords": [
    "searvora",
    "seo",
    "cli",
    "ai-agent",
    "technical-seo",
    "seo-automation"
  ],
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
